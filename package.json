{
  "name": "thinkcanvas",
  "version": "0.1.0",
  "description": "AI-driven thinking space with infinite canvas",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "ELECTRON_SKIP=1 vite",
    "build": "npm run build:electron && vite build && electron-builder",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "npm run build:electron && electron .",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@xyflow/react": "^12.4.4",
    "electron-store": "^8.2.0",
    "html2canvas": "^1.4.1",
    "idb-keyval": "^6.2.1",
    "jose": "^6.2.2",
    "mammoth": "^1.12.0",
    "openai": "^4.85.4",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/html2canvas": "^0.5.35",
    "@types/node": "^22.13.9",
    "@types/pdfjs-dist": "^2.10.377",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.thinkcanvas.app",
    "productName": "ThinkCanvas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  }
}
